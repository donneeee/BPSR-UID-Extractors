#!/usr/bin/env node
const fs = require("node:fs");
const path = require("node:path");

const TERM_HEAVY_ATTACK_ID = 590395509;
const TERM_AOE_ID = 590395740;
const TERM_ENHANCED_HEAVY_ATTACK_DAMAGE_ID = 1713188705;
const DOUBLE_ARROW_DESCRIPTION_ID = 1505374897;
const QUADRAFLARE_RECOUNT_ID = 78;
const QUADRAFLARE_AOE_BUFF_ID = 55235;
const TRUSTED_SHORT_CJK_SUFFIX_TERMS = new Set(["普攻", "落石", "分摊", "分攤", "尾刺"]);
const UNINFORMATIVE_LOCALIZED_TERM_EN = new Set([
  "a",
  "all",
  "an",
  "and",
  "area",
  "at",
  "attack",
  "before",
  "by",
  "damage",
  "deal",
  "deals",
  "during",
  "each",
  "effect",
  "enemy",
  "every",
  "for",
  "from",
  "in",
  "nearby",
  "of",
  "on",
  "or",
  "skill",
  "target",
  "targets",
  "test",
  "the",
  "this",
  "to",
  "up to",
  "when",
  "while",
  "with",
  "within"
]);

main().catch((error) => {
  console.error(error.stack || error.message || String(error));
  process.exit(1);
});

async function main() {
  const {
    choosePreferredLocaleText,
    displayPath,
    loadMetaEntries,
    maybeWriteJson,
    parseArgs,
    printHelp,
    resolvePaths
  } = await import("./generator-common.mjs");

  const args = parseArgs(process.argv.slice(2));

  if (args.help) {
    printHelp(
      "SkillBreakdownDetails.gen - generate runtime damage-row detail metadata for DPS breakdowns.",
      `
Notes:
  Reads generated DamageAttrIdName.json, RecountTable.json, and skillnames.json
  outputs. Those files are direct current-game extracts from DamageAttrTable.ctb,
  RecountTable.ctb, SkillTable.ctb, SkillEffectTable.ctb, and related bridges.
  This generator does not read parser files, probe samples, or old JSONs.
`
    );
    process.exit(0);
  }

  const paths = resolvePaths(args, "SkillBreakdownDetails.json");
  const containerDir = path.dirname(paths.m0Path);
  const metaEntries = loadMetaEntries(containerDir);
  const damageRows = readRequiredJson(path.join(paths.outputDir, "DamageAttrIdName.json"));
  const recountRows = readRequiredJson(path.join(paths.outputDir, "RecountTable.json"));
  const skillRows = readOptionalJson(path.join(paths.outputDir, "skillnames.json"), {});
  const damageToRecount = buildDamageToRecount(recountRows);
  const out = {};
  const stats = new Map();

  for (const [id, rawRow] of Object.entries(damageRows || {})) {
    const row = rawRow && typeof rawRow === "object" ? rawRow : {};
    const recount = damageToRecount.get(String(id)) ?? null;
    const category = classifyBreakdownRow(row, recount);
    const directNames = normalizeNames(row.Names, row.NameDesign || row.Name);
    const linkedSkillId = firstDefined(
      row.LinkedSkillTableId,
      row.LinkedSkillEffectSkillTableId,
      row.LinkedSkillFightSkillId,
      row.LinkedSkillTableNameMatchId
    );
    const linkedSkillMeta = resolveSkillMeta(skillRows, linkedSkillId);
    const underlying = resolveUnderlyingSkillDisplay(row);
    const sourceClassification = buildSourceClassification({
      category,
      row,
      recount,
      linkedSkillId,
      linkedSkillMeta
    });
    const linked = resolveLinkedDisplay(row, category, recount);
    const displayNames = chooseDisplayNames({ row, recount, category, linked, directNames, sourceClassification });
    const displayName =
      choosePreferredLocaleText(displayNames) ||
      choosePreferredLocaleText(directNames) ||
      linked.name ||
      recount?.Name ||
      String(row.Name || row.NameDesign || id);
    const displayDetail = chooseDisplayDetail({
      row,
      recount,
      category,
      linked,
      underlying,
      displayNames,
      sourceClassification
    });
    const reasons = buildReasons(row, recount, category, sourceClassification);
    const sourceFiles = buildSourceFiles(row, recount, sourceClassification);
    const preferredIcon = choosePreferredIcon(row, linked, recount, sourceClassification);

    out[String(id)] = stripEmpty({
      Id: numberOrString(id),
      DisplayName: displayName,
      DisplayNames: displayNames,
      DisplayDetailName: displayDetail.name,
      DisplayDetailNames: displayDetail.names,
      DisplayDetailKind: displayDetail.kind,
      DisplayDetailSource: displayDetail.source,
      DisplayDetailEvidence: displayDetail.evidence,
      Category: category.key,
      SourceKind: category.key,
      SourceType: sourceClassification.type,
      SourceRole: sourceClassification.role,
      ...(sourceClassification.isBaseSkill ? { IsBaseSkillSource: true } : {}),
      ...(sourceClassification.isTalent ? { IsTalentSource: true } : {}),
      ...(sourceClassification.isPassive ? { IsPassiveSource: true } : {}),
      ...(sourceClassification.isBuff ? { IsBuffSource: true } : {}),
      ...(sourceClassification.isMechanic ? { IsMechanicSource: true } : {}),
      CategoryLabel: category.label,
      Badge: category.badge,
      Confidence: category.confidence,
      Reason: category.reason,
      Reasons: reasons,
      DamageName: row.Name || row.NameDesign || "",
      DamageNames: directNames,
      DamageKind: row.DamageKind || "",
      DetailKind: row.DetailKind || "",
      ParentRecountId: recount?.Id,
      ParentRecountName: recount?.Name || recount?.RecountName,
      ParentRecountNames: normalizeNames(recount?.Names, recount?.Name || recount?.RecountName),
      ParentBaseSkillId: recount?.LinkedBaseSkillId,
      ParentBaseSkillName: recount?.LinkedBaseSkillName,
      ParentBaseSkillNames: normalizeNames(recount?.LinkedBaseSkillNames, recount?.LinkedBaseSkillName),
      ParentBaseSkillIconPath: recount?.LinkedBaseSkillIconPath,
      BaseSkillNameBridge: recount?.BaseSkillNameBridge,
      BaseSkillNameBridgeLocaleMatches: recount?.BaseSkillNameBridgeLocaleMatches,
      ParentTalentId: recount?.LinkedTalentId,
      ParentTalentName: recount?.LinkedTalentName,
      ParentTalentNames: normalizeNames(recount?.LinkedTalentNames, recount?.LinkedTalentName),
      ParentTalentIconPath: recount?.LinkedTalentIconPath,
      TalentNameBridge: recount?.TalentNameBridge,
      TalentNameBridgeLocaleMatches: recount?.TalentNameBridgeLocaleMatches,
      TalentFormulaBridge: recount?.TalentFormulaBridge,
      TalentFormulaBridgeLocaleMatches: recount?.TalentFormulaBridgeLocaleMatches,
      LinkedTalentBuffIds: recount?.LinkedTalentBuffIds,
      LinkedTalentFormulaIds: recount?.LinkedTalentFormulaIds,
      LinkedSource: row.LinkedSource || linked.source || "",
      LinkedId: row.LinkedId,
      LinkedName: linked.name,
      LinkedNames: linked.names,
      LinkedSkillId: linkedSkillId,
      LinkedSkillKind: linkedSkillMeta.kind,
      LinkedSkillKinds: linkedSkillMeta.kinds,
      LinkedSkillEffectId: row.LinkedSkillEffectId,
      LinkedSkillTableNameMatchId: row.LinkedSkillTableNameMatchId,
      LinkedSkillTableNameMatchName: row.LinkedSkillTableNameMatchName,
      LinkedSkillTableNameMatchNames: normalizeNames(row.LinkedSkillTableNameMatchNames, row.LinkedSkillTableNameMatchName),
      LinkedSkillTableNameMatchSource: row.LinkedSkillTableNameMatchSource,
      LinkedBuffId: row.LinkedBuffId,
      BaseSkillId: sourceClassification.baseSkillId,
      TalentSkillId: sourceClassification.talentSkillId,
      BuffSourceId: sourceClassification.buffSourceId,
      MechanicRecountId: sourceClassification.mechanicRecountId,
      RecountOwnerSkillId: sourceClassification.recountOwnerSkillId,
      RecountOwnerSkillName: sourceClassification.recountOwnerSkillName,
      RecountOwnerSkillNames: sourceClassification.recountOwnerSkillNames,
      MonsterOwnerIds: sourceClassification.monsterOwnerIds,
      MonsterOwnerName: sourceClassification.monsterOwnerName,
      MonsterOwnerNames: sourceClassification.monsterOwnerNames,
      MonsterOwnerSource: sourceClassification.monsterOwnerSource,
      MonsterOwners: sourceClassification.monsterOwners,
      UnderlyingSkillId: sourceClassification.underlyingSkillId,
      UnderlyingSkillName: underlying.name,
      UnderlyingSkillNames: underlying.names,
      UnderlyingRelatedSkillIds: sourceClassification.relatedSkillIds,
      UnderlyingSkillRelations: sourceClassification.skillRelations,
      ...(sourceClassification.recountOwnerSkillMismatch ? { IsRecountOwnerSkillMismatch: true } : {}),
      ...(sourceClassification.recountOwnerNameMismatch ? { IsRecountOwnerNameMismatch: true } : {}),
      IconPath: preferredIcon.iconPath,
      IconPaths: uniqueStrings([
        preferredIcon.iconPath,
        row.IconPath,
        ...(Array.isArray(row.IconPaths) ? row.IconPaths : []),
        linked.iconPath,
        recount?.LinkedBaseSkillIconPath,
        recount?.LinkedTalentIconPath,
        recount?.IconPath,
        ...(Array.isArray(recount?.IconPaths) ? recount.IconPaths : [])
      ]),
      IconSource: preferredIcon.iconSource || row.IconSource || linked.iconSource || recount?.IconSource || "",
      SourceFiles: sourceFiles,
      SourceOffsets: uniqueNumbers([
        row.SourceOffset,
        ...(Array.isArray(row.SourceOffsets) ? row.SourceOffsets : []),
        recount?.SourceOffset
      ])
    });
    stats.set(category.key, (stats.get(category.key) ?? 0) + 1);
  }

  const collisionStats = augmentSourceCollisionDetails(out);
  const sorted = Object.fromEntries(
    Object.entries(out).sort(([left], [right]) => compareNumericStrings(left, right))
  );

  console.log(`DamageAttr rows scanned: ${Object.keys(damageRows || {}).length}`);
  console.log(`Breakdown detail entries written: ${Object.keys(sorted).length}`);
  console.log(`Source collision variants: ${collisionStats.variantCount}`);
  for (const [category, count] of [...stats.entries()].sort((a, b) => b[1] - a[1] || a[0].localeCompare(b[0]))) {
    console.log(`${category}: ${count}`);
  }
  console.log(`Output: ${displayPath(paths.out)}`);
  maybeWriteJson(paths.out, sorted, Boolean(args.dryRun));
}

function readRequiredJson(filePath) {
  if (!fs.existsSync(filePath)) {
    throw new Error(`Missing required generated input: ${displayRelative(filePath)}`);
  }
  return JSON.parse(fs.readFileSync(filePath, "utf8"));
}

function readOptionalJson(filePath, fallback) {
  if (!fs.existsSync(filePath)) {
    return fallback;
  }
  return JSON.parse(fs.readFileSync(filePath, "utf8"));
}

function augmentSourceCollisionDetails(out) {
  const groups = new Map();
  for (const [id, detail] of Object.entries(out || {})) {
    if (!isSourceCollisionCandidate(detail)) {
      continue;
    }
    const key = sourceCollisionKey(detail);
    if (!key) {
      continue;
    }
    const rows = groups.get(key) || [];
    rows.push({ id, detail });
    groups.set(key, rows);
  }

  let variantCount = 0;
  for (const rows of groups.values()) {
    if (rows.length < 2) {
      continue;
    }
    const variants = rows.map((row) => chooseCollisionVariant(row.detail, rows));
    if (variants.some((variant) => !variant)) {
      continue;
    }
    const variantKeys = new Set(variants.map((variant) => compareNameText(variant.names, variant.name)));
    if (variantKeys.size !== variants.length) {
      continue;
    }
    for (let index = 0; index < rows.length; index += 1) {
      applyCollisionVariant(rows[index].detail, variants[index]);
      variantCount += 1;
    }
  }
  return { variantCount };
}

function isSourceCollisionCandidate(detail) {
  if (!detail || !detail.ParentRecountId || !detail.DisplayName || !detail.DisplayDetailName) {
    return false;
  }
  if (detail.DisplayDetailKind === "source-talent" || detail.DisplayDetailKind === "sibling-buff-family-source") {
    return true;
  }
  return detail.DisplayDetailKind === "localized-raw-term" && [
    "talent-skill",
    "passive-proc",
    "recount-owned-reused-skill-hit"
  ].includes(detail.SourceRole);
}

function sourceCollisionKey(detail) {
  return [
    detail.ParentRecountId,
    localizedSourceCollisionKey(detail.DisplayNames, detail.DisplayName),
    localizedSourceCollisionKey(detail.DisplayDetailNames, detail.DisplayDetailName),
    detail.DisplayDetailKind || "",
    detail.SourceRole || "",
    detail.Badge || "",
    detail.SourceTalentId || "",
    detail.ParentTalentId || ""
  ].join("|");
}

function localizedSourceCollisionKey(values, fallback) {
  return [
    values?.en,
    values?.["zh-CN"],
    values?.["zh-TW"],
    values?.ja,
    values?.["ko-KR"],
    values?.fr,
    values?.de,
    values?.es,
    values?.["pt-BR"],
    values?.th,
    fallback
  ]
    .filter(Boolean)
    .join("/")
    .trim()
    .toLowerCase();
}

function chooseCollisionVariant(detail, groupRows) {
  return chooseDesignSideVariant(detail, groupRows);
}

function chooseDesignSideVariant(detail, groupRows) {
  const side = extractSideVariant(rawVariantTexts(detail));
  if (!side) {
    return null;
  }
  const groupSides = new Set(groupRows.map((row) => extractSideVariant(rawVariantTexts(row.detail))?.key).filter(Boolean));
  if (groupSides.size < 2) {
    return null;
  }
  return {
    kind: "design-side",
    name: side.names.en,
    names: side.names,
    source: "DamageAttr/SkillTable design side suffix",
    evidence: stripEmpty({
      DamageAttrId: detail.Id,
      LinkedSkillId: detail.LinkedSkillId,
      UnderlyingSkillId: detail.UnderlyingSkillId,
      RawVariantText: side.raw
    })
  };
}

function applyCollisionVariant(detail, variant) {
  detail.DisplayVariantName = variant.name;
  detail.DisplayVariantNames = variant.names;
  detail.DisplayVariantKind = variant.kind;
  detail.DisplayVariantSource = variant.source;
  detail.DisplayVariantEvidence = variant.evidence;
}

function rawVariantTexts(detail) {
  return uniqueStringsInOrder([
    detail.DamageNames?.design,
    detail.DamageName,
    detail.UnderlyingSkillNames?.design,
    detail.UnderlyingSkillName,
    detail.LinkedNames?.design,
    detail.LinkedName
  ]);
}

function extractSideVariant(values) {
  for (const raw of values || []) {
    const text = normalizeDesignText(raw);
    if (!text) {
      continue;
    }
    if (/(?:[-_:\s]|^)(?:left|lhs|l)$/i.test(text) || /(?:[-ï¼â€”_:ï¼š]|\s|^)(?:å·¦|\u5de6)\s*$/i.test(text)) {
      return { key: "left", raw: text, names: normalizeNames({ en: "Left", design: text }, "Left") };
    }
    if (/(?:[-_:\s]|^)(?:right|rhs|r)$/i.test(text) || /(?:[-ï¼â€”_:ï¼š]|\s|^)(?:å³|\u53f3)\s*$/i.test(text)) {
      return { key: "right", raw: text, names: normalizeNames({ en: "Right", design: text }, "Right") };
    }
  }
  return null;
}

function displayRelative(filePath) {
  return path.relative(__dirname, filePath).replace(/\\/g, "/") || path.basename(filePath);
}

function buildDamageToRecount(recountRows) {
  const out = new Map();
  for (const row of Object.values(recountRows || {})) {
    if (!row || typeof row !== "object") continue;
    for (const damageId of Array.isArray(row.DamageId) ? row.DamageId : []) {
      out.set(String(damageId), row);
    }
  }
  return out;
}

function classifyBreakdownRow(row, recount) {
  const text = searchableText(row, recount);
  const damageKind = String(row.DamageKind || "");
  const parentName = `${recount?.Name || ""} ${recount?.RecountName || ""}`;
  const iconText = String(
    row.IconPath ||
    row.LinkedBuffIconPath ||
    recount?.LinkedTalentIconPath ||
    recount?.IconPath ||
    ""
  ).toLowerCase();
  const linkedSource = String(row.LinkedSource || "");

  if (/lucky/i.test(damageKind) || /幸运|lucky/i.test(text) || /Lucky Strike/i.test(parentName)) {
    return category("lucky-strike", "Lucky Strike", "Lucky", "DamageKind/name marks lucky-hit damage.", 95);
  }
  if (/套装|set effect|set-effect|\bset\b/i.test(text)) {
    return category("set-effect", "Set effect", "Set", "Damage/name marks a set effect.", 92);
  }
  if (recount?.LinkedTalentId || recount?.TalentNameBridge) {
    return category("talent-skill", "Talent", "Talent", "Recount parent links to the talent/passive table.", 94);
  }
  if (/talent|天赋/i.test(text) || iconText.includes("talent")) {
    return category("talent-skill", "Talent", "Talent", "Name/icon path marks a talent-linked row.", 90);
  }
  if (/Arcane!|Secret Art!|奥义|奧義|Imagine/i.test(parentName) || /Arcane!|Secret Art!|奥义|奧義|Imagine/i.test(text)) {
    return category("imagine", "Imagine/Arcane", "Imagine", "Parent or linked row is an Arcane/Imagine entry.", 88);
  }
  if (/被动|passive/i.test(text)) {
    return category("passive-proc", "Passive proc", "Passive", "Name marks a passive-triggered row.", 86);
  }
  if (/触发|trigger|proc/i.test(text)) {
    return category("skill-proc", "Skill proc", "Proc", "Name marks a triggered skill row.", 82);
  }
  if (/BuffName/i.test(linkedSource)) {
    return category("buff-proc", "Buff proc", "Buff", "DamageAttr row links directly to BuffName.", 80);
  }
  if (
    row.LinkedSkillId ||
    row.LinkedSkillTableId ||
    row.LinkedSkillEffectSkillTableId ||
    row.LinkedSkillFightSkillId ||
    row.LinkedSkillTableNameMatchId
  ) {
    return category("base-skill", "Base skill hit", "Base", "DamageAttr row links to a SkillTable/SkillEffect row.", 74);
  }
  if (recount) {
    return category("mechanic", "Recount mechanic", "Mechanic", "Row is grouped by RecountTable but has no deeper linked source.", 65);
  }
  return category("unknown", "Unknown", "Unknown", "No direct linked source was found.", 30);
}

function category(key, label, badge, reason, confidence) {
  return { key, label, badge, reason, confidence };
}

function buildGameTerms(localizationTables, helpers) {
  const { buildLocaleTextObject } = helpers;
  return {
    heavyAttack: collectLocalizedTerm(TERM_HEAVY_ATTACK_ID, localizationTables, buildLocaleTextObject, "Heavy Attack"),
    aoe: collectLocalizedTerm(TERM_AOE_ID, localizationTables, buildLocaleTextObject, "AoE"),
    enhancedHeavyAttackDamage: collectLocalizedTerm(
      TERM_ENHANCED_HEAVY_ATTACK_DAMAGE_ID,
      localizationTables,
      buildLocaleTextObject,
      "Enhanced heavy attack damage"
    ),
    doubleArrowDescription: collectLocalizedTerm(DOUBLE_ARROW_DESCRIPTION_ID, localizationTables, buildLocaleTextObject, ""),
    localizedTermIndex: buildLocalizedTermIndex(localizationTables, buildLocaleTextObject)
  };
}

function collectLocalizedTerm(id, localizationTables, buildLocaleTextObject, fallback) {
  const entries = [];
  for (const table of localizationTables || []) {
    const stringIndex = table.index.get(id);
    if (stringIndex === undefined) {
      return null;
    }
    const text = String(table.strings[stringIndex] || "").trim();
    if (text) {
      entries.push({ language: table.language, stringIndex, text });
    }
  }
  const names = buildLocaleTextObject(entries, fallback ? { designText: fallback } : {});
  return normalizeNames(names, fallback);
}

function buildLocalizedTermIndex(localizationTables, buildLocaleTextObject) {
  const entriesById = new Map();
  for (const table of localizationTables || []) {
    for (const [id, stringIndex] of table.index || []) {
      const texts = extractLocalizedTermTexts(table.strings?.[stringIndex], table.language);
      if (!texts.length) {
        continue;
      }
      const entries = entriesById.get(id) || [];
      for (const text of texts) {
        entries.push({ language: table.language, stringIndex, text });
      }
      entriesById.set(id, entries);
    }
  }

  const byText = new Map();
  const cjkTerms = [];
  const cjkTermsByFragment = new Map();
  const cjkTermSeen = new Set();
  for (const [id, entries] of entriesById) {
    const names = buildLocaleTextObject(entries, { includeDesign: false });
    if (!names.en) {
      continue;
    }
    if (!isUsefulLocalizedTermCandidate(names)) {
      continue;
    }
    const candidate = { id, names, entries };
    for (const entry of entries) {
      const key = normalizeTermLookupText(entry.text);
      if (!key) {
        continue;
      }
      const list = byText.get(key) || [];
      list.push(candidate);
      byText.set(key, list);
      if ((entry.language === "chinese" || entry.language === "traditionalchinese") && key.length >= 2) {
        const seenKey = `${key}:${id}`;
        if (!cjkTermSeen.has(seenKey)) {
          cjkTermSeen.add(seenKey);
          const term = { key, text: entry.text, candidate };
          cjkTerms.push(term);
          for (const fragment of cjkLookupFragments(key)) {
            const fragmentList = cjkTermsByFragment.get(fragment) || [];
            fragmentList.push(term);
            cjkTermsByFragment.set(fragment, fragmentList);
          }
        }
      }
    }
  }

  return { byText, cjkTerms, cjkTermsByFragment };
}

function extractLocalizedTermTexts(value, language) {
  const out = [];
  for (const fragment of extractTaggedLocalizedTermFragments(value)) {
    if (isLocalizedTermText(fragment)) {
      out.push(fragment);
    }
  }
  const text = cleanLocalizationTerm(value);
  for (const fragment of extractLocalizedTermFragments(text, language)) {
    if (isLocalizedTermText(fragment)) {
      out.push(fragment);
    }
  }
  if (isLocalizedTermText(text)) {
    out.push(text);
  }
  return uniqueStringsInOrder(out);
}

function extractTaggedLocalizedTermFragments(value) {
  const raw = String(value || "");
  const out = [];
  const add = (fragment) => {
    const text = cleanLocalizationTerm(fragment)
      .replace(/^[\s"'“”]+|[\s"'“”]+$/g, "")
      .trim();
    if (text && text.length >= 2 && text.length <= 48) {
      out.push(text);
    }
  };

  const styleRegex = /<style\b[^>]*>([^<>]{2,96})<\/style>/gi;
  for (const match of raw.matchAll(styleRegex)) {
    add(match[1]);
  }

  const linkRegex = /<linktext=[^>]*>(?:<style\b[^>]*>)?([^<>]{2,96})(?:<\/style>)?<\/linktext>/gi;
  for (const match of raw.matchAll(linkRegex)) {
    add(match[1]);
  }

  return uniqueStringsInOrder(out);
}

function cleanLocalizationTerm(value) {
  return String(value || "")
    .replace(/[\u200b-\u200f\ufeff]/g, "")
    .replace(/<br\s*\/?>/gi, " ")
    .replace(/<[^>]*>/g, "")
    .replace(/\{[^}]*\}/g, "")
    .replace(/\s+/g, " ")
    .trim();
}

function isLocalizedTermText(value) {
  const text = String(value || "").trim();
  if (!text || text.length > 64) return false;
  if (/[{}<>]/.test(text)) return false;
  if (/[\r\n]/.test(text)) return false;
  if (/[。.!?！？；;]/.test(text)) return false;
  if (/%|\d+\s*秒|\d+\s*s\b|\d+\s*m\b/i.test(text)) return false;
  return true;
}

function extractLocalizedTermFragments(value, language) {
  const text = String(value || "").trim();
  if (!text) {
    return [];
  }
  const out = [];
  const add = (fragment) => {
    const cleaned = cleanLocalizationTerm(fragment)
      .replace(/^[\s"'“”]+|[\s"'“”]+$/g, "")
      .trim();
    if (cleaned && cleaned.length >= 2 && cleaned.length <= 48) {
      out.push(cleaned);
    }
  };

  const leadingLabel = text.match(/^([^:：。.!?！？；;]{2,48})[:：]\s*(.+)$/);
  if (leadingLabel) {
    for (const fragment of splitMechanicLabelFragments(leadingLabel[1])) {
      add(fragment);
    }
    const rightSide = cleanLocalizationTerm(leadingLabel[2]);
    if (isLocalizedTermText(rightSide)) {
      add(rightSide);
    } else {
      add(leadingLabel[1]);
    }
  }

  const dashParts = text.split(/\s*[-–—－]\s*/).filter(Boolean);
  if (dashParts.length >= 2) {
    add(dashParts[dashParts.length - 1]);
  }

  const lang = String(language || "").toLowerCase();
  const targetedPatterns = {
    english: /Targeted by\s+([^!.,;:]{2,48})/i,
    chinese: /(?:被|受到)([^，,。.!！？?]{2,32}?)(?:点名|點名)/,
    traditionalchinese: /(?:被|受到)([^，,。.!！？?]{2,32}?)(?:点名|點名)/,
    japanese: /あなたは(.{2,32}?)(?:のターゲット|の対象)/,
    korean: /당신은\s*(.{2,32}?)(?:의 대상으로|의 대상)/,
    french: /Cibl[ée] par\s+([^!.,;:]{2,48})/i,
    german: /Vom\s+([^!.,;:]{2,48}?)\s+markiert/i,
    spanish: /ha marcado\s+(?:el|la|los|las)?\s*([^!.,;:]{2,48})/i,
    portuguese: /Alvo d[ao]\s+([^!.,;:]{2,48})/i,
    indonesian: /ditandai oleh\s*([^,!.;:]{2,48})/i
  };
  const targetedMatch = text.match(targetedPatterns[lang]);
  if (targetedMatch) {
    add(targetedMatch[1]);
  }

  for (const fragment of extractGuideMechanicFragments(text, lang)) {
    add(fragment);
  }

  return uniqueStringsInOrder(out);
}

function splitMechanicLabelFragments(value) {
  const text = cleanLocalizationTerm(value);
  if (!text) {
    return [];
  }
  const parts = text.split(/\s*(?:[-–—－·])\s*/).filter(Boolean);
  if (parts.length < 2) {
    return [];
  }
  return [parts[0], parts.slice(0, 2).join(" ")];
}

function extractGuideMechanicFragments(value, lang) {
  const text = cleanLocalizationTerm(value);
  const out = [];
  const addMatch = (regex, group = 1) => {
    for (const match of text.matchAll(regex)) {
      const fragment = cleanGuideMechanicFragment(match[group]);
      if (fragment) {
        out.push(fragment);
      }
    }
  };

  if (lang === "chinese" || lang === "traditionalchinese") {
    addMatch(/场地中(?:的)?([^，,。.!！？?；;]{2,18})/g);
    addMatch(/(?:集中|分散)放置([^，,。.!！？?；;]{2,18})/g);
    addMatch(/消灭(?:场地中(?:的)?)?([^，,。.!！？?；;]{2,18})/g);
    addMatch(/释放([^，,。.!！？?；;]{2,18}?)(?:攻击|技能|招式|伤害|傷害)/g);
  } else if (lang === "english") {
    addMatch(/(?:eliminate|group|spread out)\s+(?:the\s+)?([A-Z][A-Za-z' ]{2,48}?)(?:\s+(?:on the field|together)|[!.,;:]|$)/gi);
    addMatch(/(?:uses?|casts?|unleashes?)\s+(?:the\s+)?([A-Z][A-Za-z' ]{2,48}?)(?:\s+(?:attack|skill|damage)|[!.,;:]|$)/gi);
  }

  return uniqueStringsInOrder(out);
}

function cleanGuideMechanicFragment(value) {
  return cleanLocalizationTerm(value)
    .replace(/^(?:the|a|an)\s+/i, "")
    .replace(/(?:攻击|技能|招式|伤害|傷害|效果|区域|區域)$/i, "")
    .replace(/\s+(?:attack|skill|damage|effect|zone|area)$/i, "")
    .trim();
}

function resolveSkillMeta(skillRows, skillId) {
  const row = skillId === undefined || skillId === null ? null : skillRows?.[String(skillId)];
  if (!row || typeof row !== "object") {
    return { kind: "", kinds: [], isBaseSkill: false, isTalent: false, isPassive: false };
  }
  const kinds = uniqueStrings([
    row.Kind,
    ...(Array.isArray(row.Kinds) ? row.Kinds : [])
  ]);
  return {
    kind: String(row.Kind || kinds[0] || ""),
    kinds,
    isBaseSkill: Boolean(row.IsBaseSkill || row.Kind === "base-skill" || kinds.includes("skill-table")),
    isTalent: Boolean(row.IsTalent || row.Kind === "talent" || kinds.includes("talent")),
    isPassive: Boolean(row.IsPassive || row.Kind === "passive" || kinds.includes("passive")),
    monsterOwnerIds: Array.isArray(row.MonsterOwnerIds) ? row.MonsterOwnerIds : [],
    monsterOwnerName: String(row.MonsterOwnerName || ""),
    monsterOwnerNames: normalizeNames(row.MonsterOwnerNames, row.MonsterOwnerName),
    monsterOwnerSource: String(row.MonsterOwnerSource || ""),
    monsterOwners: Array.isArray(row.MonsterOwners) ? row.MonsterOwners : [],
    relatedSkillIds: Array.isArray(row.RelatedSkillIds) ? row.RelatedSkillIds : [],
    skillRelations: Array.isArray(row.SkillRelations) ? row.SkillRelations : []
  };
}

function buildSourceClassification({ category, row, recount, linkedSkillId, linkedSkillMeta }) {
  const key = category.key;
  const recountTalentId = firstDefined(recount?.LinkedTalentId, recount?.TalentId);
  const recountBaseSkillId = firstDefined(recount?.LinkedBaseSkillId, recount?.BaseSkillId);
  const isTalent = key === "talent-skill" || linkedSkillMeta.isTalent || recountTalentId !== undefined;
  const isPassive = key === "passive-proc" || linkedSkillMeta.isPassive;
  const isBuff = key === "buff-proc" || row.LinkedSource === "BuffName" || row.LinkedBuffId !== undefined;
  const isBaseSkill = key === "base-skill" || linkedSkillMeta.isBaseSkill;
  const isMechanic = ["lucky-strike", "mechanic", "set-effect", "imagine"].includes(key);
  const recountOwnerSkillMismatch =
    isBaseSkill &&
    recountBaseSkillId !== undefined &&
    linkedSkillId !== undefined &&
    String(recountBaseSkillId) !== String(linkedSkillId);
  const recountOwnerNameMismatch =
    isBaseSkill &&
    !isTalent &&
    recount?.Id !== undefined &&
    recountBaseSkillId === undefined &&
    linkedSkillId !== undefined &&
    namesLookDifferent(
      recount?.Names,
      recount?.Name || recount?.RecountName,
      firstNonEmptyObject(
        row.LinkedSkillEffectSkillTableNames,
        row.LinkedSkillTableNames,
        row.LinkedSkillFightSkillTableNames,
        row.LinkedSkillTableNameMatchNames
      ),
      row.LinkedSkillEffectSkillTableName ||
        row.LinkedSkillTableName ||
        row.LinkedSkillFightSkillTableName ||
        row.LinkedSkillTableNameMatchName
    );
  const type = isTalent
    ? "talent"
    : isPassive
      ? "passive"
      : isMechanic
        ? key
        : isBuff
          ? "buff"
          : isBaseSkill
            ? "base-skill"
            : "unknown";
  const recountOwnerSkillId = isTalent ? recountTalentId : recountBaseSkillId;
  const monsterOwnerIds = Array.isArray(linkedSkillMeta.monsterOwnerIds)
    ? linkedSkillMeta.monsterOwnerIds
    : [];
  const relatedSkillIds = Array.isArray(linkedSkillMeta.relatedSkillIds)
    ? linkedSkillMeta.relatedSkillIds
    : [];
  const skillRelations = Array.isArray(linkedSkillMeta.skillRelations)
    ? linkedSkillMeta.skillRelations
    : [];
  const hasMonsterOwner =
    Boolean(monsterOwnerIds.length) ||
    Boolean(linkedSkillMeta.monsterOwnerName) ||
    hasRealLocale(linkedSkillMeta.monsterOwnerNames);
  const role = chooseSourceRole({
    key,
    type,
    row,
    linkedSkillMeta,
    recountOwnerSkillMismatch,
    recountOwnerNameMismatch,
    hasMonsterOwner
  });

  return {
    type,
    role,
    isTalent,
    isPassive,
    isBuff,
    isBaseSkill,
    isMechanic,
    baseSkillId: isBaseSkill && !isTalent ? linkedSkillId : undefined,
    talentSkillId: isTalent ? firstDefined(recountTalentId, linkedSkillId) : undefined,
    buffSourceId: isBuff ? row.LinkedBuffId : undefined,
    mechanicRecountId: isMechanic ? recount?.Id : undefined,
    recountOwnerSkillId,
    recountOwnerSkillName: isTalent
      ? recount?.LinkedTalentName
      : recount?.LinkedBaseSkillName || (recountOwnerNameMismatch ? recount?.Name || recount?.RecountName : undefined),
    recountOwnerSkillNames: isTalent
      ? normalizeNames(recount?.LinkedTalentNames, recount?.LinkedTalentName)
      : normalizeNames(
          firstNonEmptyObject(recount?.LinkedBaseSkillNames, recountOwnerNameMismatch ? recount?.Names : null),
          recount?.LinkedBaseSkillName || (recountOwnerNameMismatch ? recount?.Name || recount?.RecountName : undefined)
        ),
    monsterOwnerIds: monsterOwnerIds.length ? monsterOwnerIds : undefined,
    monsterOwnerName: hasMonsterOwner ? linkedSkillMeta.monsterOwnerName : undefined,
    monsterOwnerNames: hasMonsterOwner ? linkedSkillMeta.monsterOwnerNames : undefined,
    monsterOwnerSource: hasMonsterOwner ? linkedSkillMeta.monsterOwnerSource || "MonsterTable.SkillPool" : undefined,
    monsterOwners: hasMonsterOwner ? linkedSkillMeta.monsterOwners : undefined,
    relatedSkillIds: relatedSkillIds.length ? relatedSkillIds : undefined,
    skillRelations: skillRelations.length ? skillRelations : undefined,
    underlyingSkillId: linkedSkillId,
    recountOwnerSkillMismatch,
    recountOwnerNameMismatch
  };
}

function chooseSourceRole({ key, type, row, linkedSkillMeta, recountOwnerSkillMismatch, recountOwnerNameMismatch, hasMonsterOwner }) {
  if (key === "lucky-strike") return "lucky-strike";
  if (key === "set-effect") return "set-effect";
  if (key === "imagine") return "imagine";
  if (type === "talent") return linkedSkillMeta.isBaseSkill ? "talent-skill" : "talent-proc";
  if (type === "passive") return "passive-proc";
  if (type === "buff") return row.LinkedSkillId || row.LinkedSkillEffectId ? "buff-skill-bridge" : "buff-proc";
  if (type === "base-skill" && (recountOwnerSkillMismatch || recountOwnerNameMismatch)) {
    return "recount-owned-reused-skill-hit";
  }
  if (type === "base-skill" && hasMonsterOwner) return "monster-owned-skill-hit";
  if (type === "base-skill") return "base-skill-hit";
  if (key === "skill-proc") return "skill-proc";
  if (key === "mechanic") return "recount-mechanic";
  return "unknown";
}

function searchableText(row, recount) {
  return [
    row.Name,
    row.NameDesign,
    row.DamageKind,
    row.DetailKind,
    row.LinkedSource,
    row.LinkedBuffName,
    namesText(row.LinkedBuffNames),
    row.LinkedSkillName,
    row.LinkedSkillTableName,
    namesText(row.LinkedSkillTableNames),
    row.LinkedSkillEffectSkillTableName,
    namesText(row.LinkedSkillEffectSkillTableNames),
    row.LinkedSkillFightName,
    row.LinkedSkillFightSkillTableName,
    namesText(row.LinkedSkillFightSkillTableNames),
    row.LinkedSkillTableNameMatchName,
    namesText(row.LinkedSkillTableNameMatchNames),
    row.IconPath,
    row.LinkedBuffIconPath,
    recount?.IconPath,
    recount?.LinkedTalentIconPath,
    recount?.LinkedTalentName,
    namesText(recount?.LinkedTalentNames),
    recount?.TalentNameBridge,
    recount?.Name,
    recount?.RecountName,
    namesText(recount?.Names)
  ].filter(Boolean).join(" ");
}

function namesText(names) {
  if (!names || typeof names !== "object" || Array.isArray(names)) return "";
  return Object.values(names).filter(Boolean).join(" ");
}

function resolveLinkedDisplay(row, category, recount) {
  const candidates = [];
  if (category.key === "talent-skill" && (recount?.LinkedTalentId || recount?.TalentNameBridge)) {
    candidates.push({
      source: "RecountTable.TalentPassiveNameBridge",
      name: recount?.LinkedTalentName || recount?.Name || recount?.RecountName,
      names: normalizeNames(
        recount?.LinkedTalentNames || recount?.Names,
        recount?.LinkedTalentName || recount?.Name || recount?.RecountName
      ),
      iconPath: recount?.LinkedTalentIconPath || recount?.IconPath,
      iconSource: recount?.IconSource || "CTB:3345237628.LocalizedNameMatch"
    });
  }
  if (row.LinkedSource === "BuffName" || category.key === "buff-proc" || category.key === "lucky-strike") {
    candidates.push({
      source: "BuffName",
      name: row.LinkedBuffName,
      names: normalizeNames(row.LinkedBuffNames, row.LinkedBuffName),
      iconPath: row.LinkedBuffIconPath,
      iconSource: "BuffName"
    });
  }
  candidates.push(
    {
      source: "SkillFightLevelTable.SkillTable",
      name: row.LinkedSkillFightSkillTableName,
      names: normalizeNames(row.LinkedSkillFightSkillTableNames, row.LinkedSkillFightSkillTableName),
      iconPath: row.LinkedSkillFightSkillIconPath,
      iconSource: "SkillFightLevelTableSkillIdToSkillTable"
    },
    {
      source: "SkillEffectTable.SkillTable",
      name: row.LinkedSkillEffectSkillTableName,
      names: normalizeNames(row.LinkedSkillEffectSkillTableNames, row.LinkedSkillEffectSkillTableName),
      iconPath: row.LinkedSkillEffectSkillTableIconPath,
      iconSource: "SkillEffectTableSkillIdToSkillTable"
    },
    {
      source: "SkillTable",
      name: row.LinkedSkillTableName,
      names: normalizeNames(row.LinkedSkillTableNames, row.LinkedSkillTableName),
      iconPath: row.LinkedSkillTableIconPath,
      iconSource: "SkillTable"
    },
    {
      source: "DamageAttrTable.NameDesignExactSkillTableMatch",
      name: row.LinkedSkillTableNameMatchName,
      names: normalizeNames(row.LinkedSkillTableNameMatchNames, row.LinkedSkillTableNameMatchName),
      iconPath: row.LinkedSkillTableNameMatchIconPath,
      iconSource: "DamageAttrNameExactSkillTable"
    },
    {
      source: "SkillEffectTable",
      name: row.LinkedSkillName,
      names: normalizeNames(null, row.LinkedSkillName),
      iconPath: "",
      iconSource: ""
    },
    {
      source: "BuffName",
      name: row.LinkedBuffName,
      names: normalizeNames(row.LinkedBuffNames, row.LinkedBuffName),
      iconPath: row.LinkedBuffIconPath,
      iconSource: "BuffName"
    }
  );

  for (const candidate of candidates) {
    if (candidate.name || Object.keys(candidate.names || {}).length) {
      return {
        ...candidate,
        name: candidate.name || chooseAnyName(candidate.names)
      };
    }
  }
  return { source: "", name: "", names: {}, iconPath: "", iconSource: "" };
}

function resolveUnderlyingSkillDisplay(row) {
  const candidates = [
    {
      name: row.LinkedSkillFightSkillTableName,
      names: normalizeNames(row.LinkedSkillFightSkillTableNames, row.LinkedSkillFightSkillTableName)
    },
    {
      name: row.LinkedSkillEffectSkillTableName,
      names: normalizeNames(row.LinkedSkillEffectSkillTableNames, row.LinkedSkillEffectSkillTableName)
    },
    {
      name: row.LinkedSkillTableName,
      names: normalizeNames(row.LinkedSkillTableNames, row.LinkedSkillTableName)
    },
    {
      name: row.LinkedSkillTableNameMatchName,
      names: normalizeNames(row.LinkedSkillTableNameMatchNames, row.LinkedSkillTableNameMatchName)
    },
    {
      name: row.LinkedSkillName,
      names: normalizeNames(null, row.LinkedSkillName)
    }
  ];

  for (const candidate of candidates) {
    if (candidate.name || Object.keys(candidate.names || {}).length) {
      return {
        name: candidate.name || chooseAnyName(candidate.names),
        names: candidate.names || {}
      };
    }
  }
  return { name: "", names: {} };
}

function chooseDisplayNames({ row, recount, category, linked, directNames, sourceClassification }) {
  if (sourceClassification?.recountOwnerSkillMismatch || sourceClassification?.recountOwnerNameMismatch) {
    const ownerNames = firstNonEmptyObject(recount?.LinkedBaseSkillNames, recount?.Names);
    return normalizeNames(
      ownerNames,
      recount?.LinkedBaseSkillName || recount?.Name || recount?.RecountName || linked.name || row.Name || row.NameDesign
    );
  }

  if (category.key === "talent-skill" && (recount?.LinkedTalentId || recount?.TalentNameBridge)) {
    const talentNames = firstNonEmptyObject(recount?.LinkedTalentNames, recount?.Names);
    return normalizeNames(
      talentNames,
      recount?.LinkedTalentName || recount?.Name || recount?.RecountName || linked.name || row.Name || row.NameDesign
    );
  }

  if (category.key === "talent-skill" && !hasRealLocale(linked?.names) && hasRealLocale(recount?.Names)) {
    return normalizeNames(recount.Names, recount?.Name || recount?.RecountName || linked.name || row.Name || row.NameDesign);
  }

  if (category.key === "base-skill") {
    const skillNames = firstNonEmptyObject(
      row.LinkedSkillEffectSkillTableNames,
      row.LinkedSkillTableNames,
      row.LinkedSkillFightSkillTableNames,
      row.LinkedSkillTableNameMatchNames
    );
    const rawSkillName =
      row.LinkedSkillEffectSkillTableName ||
      row.LinkedSkillTableName ||
      row.LinkedSkillFightSkillTableName ||
      row.LinkedSkillTableNameMatchName ||
      recount?.Name ||
      row.Name;
    if (!hasRealLocale(skillNames) && hasRealLocale(sourceClassification?.monsterOwnerNames)) {
      return normalizeNames(sourceClassification.monsterOwnerNames, sourceClassification.monsterOwnerName);
    }
    return normalizeNames(skillNames, rawSkillName);
  }

  if (["talent-skill", "passive-proc", "set-effect", "skill-proc"].includes(category.key)) {
    const linkedNames = firstNonEmptyObject(
      row.LinkedSkillFightSkillTableNames,
      row.LinkedSkillTableNames,
      row.LinkedSkillEffectSkillTableNames,
      row.LinkedSkillTableNameMatchNames,
      recount?.LinkedTalentNames,
      recount?.Names,
      linked.names
    );
    const rawLinkedName =
      row.LinkedSkillFightSkillTableName ||
      row.LinkedSkillTableName ||
      row.LinkedSkillEffectSkillTableName ||
      row.LinkedSkillTableNameMatchName ||
      recount?.LinkedTalentName ||
      recount?.Name ||
      recount?.RecountName ||
      row.Name ||
      row.NameDesign;
    return normalizeNames(linkedNames, rawLinkedName);
  }

  if (["buff-proc", "lucky-strike", "imagine"].includes(category.key)) {
    if (recount?.Id !== undefined && !hasRealLocale(row.LinkedBuffNames) && !hasRealLocale(linked.names)) {
      return normalizeNames(recount?.Names, recount?.Name || recount?.RecountName || row.LinkedBuffName || row.Name || row.NameDesign);
    }
    const buffNames = firstNonEmptyObject(row.LinkedBuffNames, linked.names);
    return normalizeNames(buffNames, row.LinkedBuffName || row.Name || row.NameDesign);
  }

  return Object.keys(directNames || {}).length
    ? directNames
    : normalizeNames(recount?.Names, recount?.Name || row.Name || row.NameDesign);
}

function chooseLocalizedRawDisplayBridge(row, category, gameTerms) {
  const rawValues = rawDisplayValuesForRow(row, category);
  for (const rawValue of rawValues) {
    const bridge = resolveLocalizedDesignTerm(rawValue, gameTerms, { composeRoleNames: true });
    if (isOwnerOnlyInternalDesignBridge(rawValue, bridge)) {
      continue;
    }
    if (bridge?.names && hasRealLocale(bridge.names)) {
      return {
        ...bridge,
        kind: bridge.roles?.isAoe ? "localized-raw-display-aoe" : "localized-raw-display"
      };
    }
  }
  return null;
}

function rawDisplayValuesForRow(row, category) {
  const preferred = [];
  if (category?.key === "buff-proc" || category?.key === "lucky-strike") {
    preferred.push(row.LinkedBuffName, row.Name, row.NameDesign);
    return uniqueStringsInOrder(preferred);
  }

  preferred.push(
    row.LinkedSkillFightSkillTableName,
    row.LinkedSkillEffectSkillTableName,
    row.LinkedSkillTableName,
    row.LinkedSkillTableNameMatchName,
    row.LinkedSkillName,
    row.LinkedBuffName
  );
  const linkedOnly = uniqueStringsInOrder(preferred);
  if (linkedOnly.length) {
    return linkedOnly;
  }
  return rawDesignValuesForRow(row, category);
}

function chooseLocalizedRawDesignDetail({ row, recount, category, displayNames, gameTerms }) {
  const displayCompare = compareNameText(displayNames, recount?.Name || recount?.RecountName || row.Name || row.NameDesign);
  for (const rawValue of rawDesignValuesForRow(row, category)) {
    const bridge = resolveLocalizedDesignTerm(rawValue, gameTerms);
    if (isOwnerOnlyInternalDesignBridge(rawValue, bridge)) {
      continue;
    }
    if (!bridge?.names || !hasRealLocale(bridge.names)) {
      return null;
    }
    if (hasWeakLocalizedSourceName(bridge.names)) {
      continue;
    }
    if (!hasExactCjkLocalizedTermMatch(bridge)) {
      continue;
    }
    if (namesContainLookupText(displayNames, rawValue)) {
      return null;
    }

    const bridgeCompare = compareNameText(bridge.names, bridge.name);
    if (bridgeCompare && bridge.roles?.isAoe && displayCompare.includes(bridgeCompare) && displayLooksLikeAoe(displayNames, bridge.name)) {
      return null;
    }
    if (bridgeCompare && bridgeCompare === displayCompare) {
      if (bridge.roles?.isAoe && !displayLooksLikeAoe(displayNames, bridge.name)) {
        const names = normalizeNames(gameTerms?.aoe, "AoE");
        if (rawValue) names.design = rawValue;
        return {
          kind: "localized-area-term",
          name: chooseAnyName(names),
          names,
          source: "DamageAttr/Buff design suffix plus localized game term",
          evidence: stripEmpty({
            DamageAttrId: row.Id,
            BuffId: row.LinkedBuffId,
            RawDesignName: rawValue,
            LocalizedTermId: bridge.id,
            AreaTermId: TERM_AOE_ID
          })
        };
      }
      return null;
    }

    const names = normalizeNames(bridge.names, bridge.name);
    if (rawValue) names.design = rawValue;
    return {
      kind: bridge.roles?.isAoe ? "localized-raw-aoe" : "localized-raw-term",
      name: chooseAnyName(names),
      names,
      source: "DamageAttr/Buff design base matched a localized game term",
      evidence: stripEmpty({
        DamageAttrId: row.Id,
        BuffId: row.LinkedBuffId,
        RawDesignName: rawValue,
        LocalizedTermId: bridge.id
      })
    };
  }
  return null;
}

function rawDesignValuesForRow(row, category) {
  const preferred = [];
  if (category?.key === "buff-proc" || category?.key === "lucky-strike") {
    preferred.push(row.LinkedBuffName, row.Name, row.NameDesign);
  }
  preferred.push(
    row.LinkedSkillFightSkillTableName,
    row.LinkedSkillEffectSkillTableName,
    row.LinkedSkillTableName,
    row.LinkedSkillTableNameMatchName,
    row.LinkedSkillName,
    row.LinkedBuffName,
    row.Name,
    row.NameDesign
  );
  return uniqueStringsInOrder(preferred);
}

function resolveLocalizedDesignTerm(rawValue, gameTerms, options = {}) {
  const roles = detectDesignRoles(rawValue);
  if (roles.isFormula || roles.isLucky) {
    return null;
  }
  const candidates = deriveDesignTermCandidates(rawValue);
  for (const candidate of candidates) {
    const compound = resolveCompoundLocalizedTermCandidate(candidate.text, gameTerms, candidate.roles);
    if (compound) {
      return {
        ...compound,
        raw: rawValue,
        baseText: candidate.text,
        roles: candidate.roles
      };
    }
    const match = lookupLocalizedTerm(candidate.text, gameTerms?.localizedTermIndex);
    if (!match) {
      continue;
    }
    let names = normalizeNames(match.names, candidate.text);
    if (options.composeRoleNames && candidate.roles.isAoe && Number(match.id) !== TERM_AOE_ID) {
      names = composeLocaleNames(names, gameTerms?.aoe, candidate.text, "AoE");
    }
    return {
      id: match.id,
      name: chooseAnyName(names),
      names,
      raw: rawValue,
      baseText: candidate.text,
      roles: candidate.roles
    };
  }
  return null;
}

function resolveCompoundLocalizedTermCandidate(text, gameTerms, roles) {
  const value = normalizeDesignText(text);
  if (!value || !containsCjk(value)) {
    return null;
  }

  const summonMatch = value.match(/^(召唤|召喚)(.{2,24})$/);
  if (summonMatch) {
    const prefix = lookupLocalizedTerm(summonMatch[1], gameTerms?.localizedTermIndex);
    const suffix = lookupLocalizedTerm(summonMatch[2], gameTerms?.localizedTermIndex);
    if (prefix?.names && suffix?.names && hasRealLocale(suffix.names)) {
      const names = joinLocaleNames(prefix.names, suffix.names, summonMatch[1], summonMatch[2], " ");
      names.design = value;
      return {
        id: `${prefix.id}+${suffix.id}`,
        name: chooseAnyName(names),
        names,
        roles
      };
    }
  }

  const basicAttackMatch = value.match(/^(普攻|普通攻击|普通攻擊)(.{1,24})$/);
  if (basicAttackMatch) {
    const prefix = lookupLocalizedTerm(basicAttackMatch[1], gameTerms?.localizedTermIndex);
    if (prefix?.names && hasRealLocale(prefix.names)) {
      const names = normalizeNames(prefix.names, basicAttackMatch[1]);
      names.design = value;
      return {
        id: prefix.id,
        name: chooseAnyName(names),
        names,
        roles
      };
    }
  }

  return null;
}

function lookupLocalizedTerm(value, index) {
  const key = normalizeTermLookupText(value);
  if (!key || !index) return null;
  const exact = chooseBestLocalizedTerm(index.byText?.get(key), key);
  if (exact) {
    return exact;
  }
  if (!containsCjk(value) || key.length < 2) {
    return null;
  }

  const prefixMatches = [];
  for (const entry of collectCjkLookupTerms(key, index)) {
    if (!entry.key || entry.key === key) {
      continue;
    }
    const startsWithQuery = entry.key.startsWith(key);
    const queryStartsWithTerm = false;
    const queryEndsWithTerm = key.endsWith(entry.key);
    const entryEndsWithQuery = entry.key.endsWith(key);
    const fuzzyDistance =
      !startsWithQuery && !queryStartsWithTerm && !queryEndsWithTerm && !entryEndsWithQuery
        ? cjkEditDistanceWithin(key, entry.key, 1)
        : null;
    if (!startsWithQuery && !queryStartsWithTerm && !queryEndsWithTerm && !entryEndsWithQuery && fuzzyDistance === null) {
      continue;
    }
    const distance = fuzzyDistance ?? Math.abs(entry.key.length - key.length);
    const shortSuffixMatch = (queryEndsWithTerm && entry.key.length <= 2) || (entryEndsWithQuery && key.length <= 2);
    if (shortSuffixMatch && !TRUSTED_SHORT_CJK_SUFFIX_TERMS.has(queryEndsWithTerm ? entry.key : key)) {
      continue;
    }
    if (queryStartsWithTerm && entry.key.length <= 2) {
      continue;
    }
    if (queryEndsWithTerm && (!containsCjk(entry.key) || entry.key.length < 2 || distance > 6)) {
      continue;
    }
    if (entryEndsWithQuery && (!containsCjk(entry.key) || key.length < 2 || distance > 6)) {
      continue;
    }
    if (!queryEndsWithTerm && !entryEndsWithQuery && fuzzyDistance === null && distance > 2) {
      continue;
    }
    prefixMatches.push({ ...entry.candidate, distance, matchedKey: entry.key });
  }
  if (isAmbiguousShortCjkFallback(key, prefixMatches)) {
    return null;
  }
  return chooseBestLocalizedTerm(prefixMatches, key);
}

function isAmbiguousShortCjkFallback(key, candidates) {
  if (!containsCjk(key) || key.length > 2) {
    return false;
  }
  const englishValues = new Set();
  for (const candidate of candidates || []) {
    const english = normalizeTermLookupText(candidate?.names?.en || "");
    if (english) {
      englishValues.add(english);
    }
    if (englishValues.size > 2) {
      return true;
    }
  }
  return false;
}

function collectCjkLookupTerms(key, index) {
  const out = [];
  const seen = new Set();
  for (const fragment of cjkLookupFragments(key)) {
    for (const entry of index?.cjkTermsByFragment?.get(fragment) || []) {
      const seenKey = `${entry.key}:${entry.candidate?.id}`;
      if (seen.has(seenKey)) {
        continue;
      }
      seen.add(seenKey);
      out.push(entry);
    }
  }
  return out;
}

function cjkLookupFragments(value) {
  const text = normalizeTermLookupText(value);
  if (!containsCjk(text)) {
    return [];
  }
  const chars = [...text];
  const fragments = new Set();
  for (const size of [2, 3]) {
    if (chars.length < size) {
      continue;
    }
    for (let index = 0; index <= chars.length - size; index += 1) {
      const fragment = chars.slice(index, index + size).join("");
      if (containsCjk(fragment)) {
        fragments.add(fragment);
      }
    }
  }
  return [...fragments];
}

function cjkEditDistanceWithin(left, right, limit) {
  if (!containsCjk(left) || !containsCjk(right)) {
    return null;
  }
  if (left.length < 4 || right.length < 4) {
    return null;
  }
  if (left.length > 16 || right.length > 16) {
    return null;
  }
  if (Math.abs(left.length - right.length) > limit) {
    return null;
  }
  if (!hasSharedCjkNgram(left, right, 3)) {
    return null;
  }
  const distance = boundedLevenshtein(left, right, limit);
  return distance <= limit ? distance : null;
}

function hasSharedCjkNgram(left, right, size) {
  const leftChars = [...String(left || "")];
  const rightText = String(right || "");
  if (leftChars.length < size) {
    return false;
  }
  for (let index = 0; index <= leftChars.length - size; index += 1) {
    const fragment = leftChars.slice(index, index + size).join("");
    if (containsCjk(fragment) && rightText.includes(fragment)) {
      return true;
    }
  }
  return false;
}

function boundedLevenshtein(left, right, limit) {
  const a = [...String(left || "")];
  const b = [...String(right || "")];
  if (Math.abs(a.length - b.length) > limit) {
    return limit + 1;
  }
  let previous = Array.from({ length: b.length + 1 }, (_, index) => index);
  for (let i = 1; i <= a.length; i += 1) {
    const current = [i];
    let rowMin = current[0];
    for (let j = 1; j <= b.length; j += 1) {
      const cost = a[i - 1] === b[j - 1] ? 0 : 1;
      const value = Math.min(
        previous[j] + 1,
        current[j - 1] + 1,
        previous[j - 1] + cost
      );
      current[j] = value;
      rowMin = Math.min(rowMin, value);
    }
    if (rowMin > limit) {
      return limit + 1;
    }
    previous = current;
  }
  return previous[b.length];
}

function chooseBestLocalizedTerm(candidates, key) {
  const list = Array.isArray(candidates) ? candidates.filter(Boolean) : [];
  if (!list.length) return null;
  const sorted = [...list].sort((left, right) => {
    const leftZh = normalizeTermLookupText(left.names?.["zh-CN"] || left.names?.["zh-TW"] || "");
    const rightZh = normalizeTermLookupText(right.names?.["zh-CN"] || right.names?.["zh-TW"] || "");
    const leftDistance = left.distance ?? Math.abs(leftZh.length - key.length);
    const rightDistance = right.distance ?? Math.abs(rightZh.length - key.length);
    if (leftDistance !== rightDistance) return leftDistance - rightDistance;
    const leftEn = String(left.names?.en || "");
    const rightEn = String(right.names?.en || "");
    if (leftEn.length !== rightEn.length) return leftEn.length - rightEn.length;
    return Number(left.id) - Number(right.id);
  });
  return sorted[0];
}

function deriveDesignTermCandidates(rawValue) {
  const original = normalizeDesignText(rawValue);
  if (!original) {
    return [];
  }
  const roles = detectDesignRoles(original);
  const values = [];
  const add = (value) => {
    const text = normalizeDesignText(value);
    if (!isUsefulDesignTermCandidate(text)) {
      return;
    }
    values.push(text);
  };

  const stripped = stripDesignImplementationTokens(original);
  if (roles.isAoe || roles.isBuff || roles.isStack || roles.isVirtual || roles.isTalent) {
    add(stripped);
  } else {
    add(original);
  }
  add(stripped);
  for (const part of original.split(/[-－—_:：·]/g)) {
    add(stripDesignImplementationTokens(part));
  }

  return uniqueStringsInOrder(values).map((text) => ({ text, roles }));
}

function stripDesignImplementationTokens(value) {
  let text = normalizeDesignText(value)
    .replace(/^(?:天赋触发|天賦觸發|天赋|天賦|被动触发|被動觸發|触发|觸發)\s*[-－—_:：]?\s*/i, "")
    .replace(/[（(][^）)]{1,24}[）)]\s*$/g, "")
    .replace(/\s+/g, " ")
    .trim();

  for (let i = 0; i < 8; i += 1) {
    const next = text
      .replace(/\s*(?:[-－—_:：_ ]+)?(?:aoe子buff|子?buff\d*|buff\d*|伤害区域|傷害區域|伤害|傷害|虚拟体|虛擬體|叠层|疊層|计数|計數|检测|檢測|恢复|恢復|治疗|治療|幸运|幸運|lucky|ATK[_-]?(?:EX|\d+)|SPECIAL_SKILL_[A-Z]|\w*UTR_SKILL(?:[_-][^\s\-－—_:：]+)*|\w*SPECIAL_SKILL(?:[_-][^\s\-－—_:：]+)*|SKILL(?:[_-][^\s\-－—_:：]+)*|子弹|子彈|触发|觸發|释放|釋放|aoe)\s*$/i, "")
      .trim();
    if (next === text) break;
    text = next;
  }

  for (let i = 0; i < 4; i += 1) {
    const next = text
      .replace(/\s*(?:[-－—_:：_ ]+)?(?:英雄本S\d+|英雄本|普通本|困难|困難|噩梦|噩夢|大师|大師|大精英|小精英|精英|S\d+|P\d+阶段|P\d+階段|P\d+|E\d+)\s*$/i, "")
      .trim();
    if (next === text) break;
    text = next;
  }

  for (let i = 0; i < 4; i += 1) {
    const next = text
      .replace(/\s*(?:[-－—_:：_ ]+)?(?:普通爆炸|懲罰爆炸|惩罚爆炸|爆炸|延迟出|延遲出|二段|普通|惩罚|懲罰)\s*$/i, "")
      .trim();
    if (next === text) break;
    text = next;
  }

  return text;
}

function detectDesignRoles(value) {
  const text = String(value || "");
  return {
    isAoe: /aoe|伤害区域|傷害區域|范围|範圍|区域|區域/i.test(text),
    isBuff: /buff|子BUFF/i.test(text),
    isStack: /叠层|疊層|stack/i.test(text),
    isVirtual: /虚拟体|虛擬體/i.test(text),
    isTalent: /天赋|天賦|talent/i.test(text),
    isLucky: /幸运|幸運|lucky/i.test(text),
    isFormula: isInternalFormulaLabel(text)
  };
}

function normalizeDesignText(value) {
  return String(value || "")
    .replace(/[\u200b-\u200f\ufeff]/g, "")
    .replace(/\s+/g, " ")
    .trim();
}

function normalizeTermLookupText(value) {
  return cleanLocalizationTerm(value)
    .replace(/[“”"']/g, "")
    .replace(/\s+/g, "")
    .toLowerCase();
}

function normalizeEnglishTermText(value) {
  return String(value || "")
    .replace(/[\u200b-\u200f\ufeff]/g, "")
    .replace(/[“”"']/g, "")
    .replace(/\s+/g, " ")
    .trim()
    .toLowerCase();
}

function isUsefulLocalizedTermCandidate(names) {
  const english = normalizeEnglishTermText(names?.en);
  if (!english) return false;
  if (hasWeakLocalizedSourceName(names)) return false;
  if (UNINFORMATIVE_LOCALIZED_TERM_EN.has(english)) return false;
  if (/^[\d\s.,:+%/-]+$/.test(english)) return false;
  return true;
}

function hasWeakLocalizedSourceName(names) {
  for (const value of Object.values(names || {})) {
    const text = normalizeEnglishTermText(value);
    if (!text) continue;
    if (UNINFORMATIVE_LOCALIZED_TERM_EN.has(text)) return true;
    if (/\btest\b/i.test(text)) return true;
    if (/[\u6d4b\u8bd5\u6e2c\u8a66]/.test(String(value || ""))) return true;
  }
  return false;
}

function isUsefulDesignTermCandidate(value) {
  const text = String(value || "").trim();
  if (!text || text.length < 2 || text.length > 32) return false;
  if (/^(?:buff|aoe|lucky|skill|attack|damage|ATK[_-]?(?:EX|\d+)|SPECIAL_SKILL|UTR_SKILL)$/i.test(text)) return false;
  if (/^(?:英雄本|普通本|困难|困難|噩梦|噩夢|大师|大師|精英|大精英|小精英|英雄本S\d+|S\d+|P\d+|阶段|階段)$/i.test(text)) return false;
  if (/^[A-Za-z0-9_ -]+$/.test(text) && !/[A-Za-z]{3}/.test(text)) return false;
  return true;
}

function displayLooksLikeAoe(names, fallback) {
  return /aoe|area|区域|區域|范围|範圍|全场|全場/i.test(namesText(names) || fallback || "");
}

function uniqueStringsInOrder(values) {
  const seen = new Set();
  const out = [];
  for (const value of values || []) {
    const text = String(value || "").trim();
    if (!text || seen.has(text)) {
      continue;
    }
    seen.add(text);
    out.push(text);
  }
  return out;
}

function chooseDisplayDetail({
  row,
  recount,
  category,
  linked,
  underlying,
  displayNames,
  sourceClassification
}) {
  const displayCompare = compareNameText(displayNames, recount?.Name || recount?.RecountName || row.Name || row.NameDesign);
  const underlyingCompare = compareNameText(underlying?.names, underlying?.name);
  const gameFileDetail = chooseGameFileDerivedDetail({
    row,
    recount,
    category,
    underlying,
    sourceClassification
  });
  if (gameFileDetail) {
    return gameFileDetail;
  }

  if (
    underlyingCompare &&
    underlyingCompare !== displayCompare &&
    hasRealLocale(underlying?.names) &&
    (sourceClassification?.underlyingSkillId !== undefined || category.key === "base-skill")
  ) {
    const underlyingLooksInternal =
      isInternalFormulaLabel(underlying?.name) ||
      hasImplementationToken(underlying?.name) ||
      hasImplementationToken(chooseAnyName(underlying?.names)) ||
      containsCjk(underlying?.name);
    const localizedUnderlyingLooksInternal =
      isInternalFormulaLabel(chooseAnyName(underlying?.names)) ||
      hasImplementationToken(chooseAnyName(underlying?.names)) ||
      hasInternalSkillImplementationToken(chooseAnyName(underlying?.names));
    if (
      underlyingLooksInternal &&
      hasRealLocale(displayNames) &&
      localizedUnderlyingLooksInternal
    ) {
      return { kind: "", name: "", names: {} };
    }
    return {
      kind: "underlying-skill",
      name: chooseAnyName(underlying?.names),
      names: normalizeNames(underlying.names, underlying.name)
    };
  }

  if (category.key === "buff-proc" || category.key === "lucky-strike") {
    const rawName = row.LinkedBuffName || linked?.name || row.Name || row.NameDesign;
    if (normalizeCompareText(rawName) === displayCompare) {
      return { kind: "", name: "", names: {} };
    }
    if (!hasRealLocale(row.LinkedBuffNames)) {
      return { kind: "", name: "", names: {} };
    }
    return {
      kind: "buff",
      name: chooseAnyName(row.LinkedBuffNames),
      names: normalizeNames(row.LinkedBuffNames, rawName)
    };
  }

  return { kind: "", name: "", names: {} };
}

function chooseGameFileDerivedDetail({
  row,
  recount,
  category,
  underlying,
  sourceClassification
}) {
  if (isMonsterOwnedInternalSkill(row, category, sourceClassification)) {
    const skillId =
      sourceClassification.underlyingSkillId ||
      row.LinkedSkillEffectSkillTableId ||
      row.LinkedSkillTableId ||
      row.LinkedSkillFightSkillId ||
      row.LinkedSkillTableNameMatchId;
    const rawSkillName =
      row.LinkedSkillEffectSkillTableName ||
      row.LinkedSkillTableName ||
      row.LinkedSkillFightSkillTableName ||
      row.LinkedSkillTableNameMatchName ||
      underlying?.name ||
      row.NameDesign ||
      row.Name;
    const skillNames = firstNonEmptyObject(
      row.LinkedSkillEffectSkillTableNames,
      row.LinkedSkillTableNames,
      row.LinkedSkillFightSkillTableNames,
      row.LinkedSkillTableNameMatchNames,
      underlying?.names
    );
    if (!hasRealLocale(skillNames)) {
      return null;
    }
    const names = normalizeNames(skillNames, rawSkillName);
    return {
      kind: "monster-skill-owner",
      name: chooseAnyName(names),
      names,
      source: "MonsterTable skill pool plus linked SkillTable localization",
      evidence: stripEmpty({
        DamageAttrId: row.Id,
        DamageAttrName: row.NameDesign || row.Names?.design || row.Name,
        SkillTableId: skillId,
        SkillTableNameDesign: rawSkillName,
        MonsterOwnerIds: Array.isArray(sourceClassification.monsterOwnerIds)
          ? sourceClassification.monsterOwnerIds.join(",")
          : "",
        MonsterOwnerName: sourceClassification.monsterOwnerName
      })
    };
  }

  return null;
}

function chooseSourceTalentDetail(row, recount, displayNames, category) {
  if (!recount?.LinkedSourceTalentId) {
    return null;
  }
  if (recount.SourceTalentBridge === "CTB:3345237628.SkillTriggerMatch") {
    // Skill-trigger source-talent bridges are static game-file evidence, not a player loadout.
    // Showing them as child labels can leak another spec into the breakdown.
    return null;
  }
  const names = normalizeNames(recount.LinkedSourceTalentNames, recount.LinkedSourceTalentName);
  if (!hasRealLocale(names)) {
    return null;
  }
  if (hasWeakLocalizedSourceName(names)) {
    return null;
  }
  const sourceCompare = compareNameText(names, recount.LinkedSourceTalentName);
  const displayCompare = compareNameText(displayNames, row.DisplayName || row.Name || row.NameDesign);
  if (sourceCompare && displayCompare && sourceCompare === displayCompare) {
    return null;
  }
  return {
    kind: "source-talent",
    name: chooseAnyName(names),
    names,
    source: "Talent/passive table skill trigger match",
    evidence: stripEmpty({
      DamageAttrId: row.Id,
      RecountId: recount?.Id,
      SourceTalentId: recount.LinkedSourceTalentId,
      MatchedSkillIds: Array.isArray(recount.LinkedSourceTalentSkillIds)
        ? recount.LinkedSourceTalentSkillIds.join(",")
        : "",
      SourceTalentBridge: recount.SourceTalentBridge
    })
  };
}

function chooseSiblingBuffFamilySourceDetail(row, recount, siblingSourceDetails) {
  const key = siblingBuffFamilyKey(recount?.Id, row.LinkedBuffId);
  if (!key) {
    return null;
  }
  const detail = siblingSourceDetails?.get(key);
  if (!detail || detail.ambiguous || !hasRealLocale(detail.names)) {
    return null;
  }
  return {
    kind: "sibling-buff-family-source",
    name: chooseAnyName(detail.names),
    names: detail.names,
    source: "Sibling DamageAttr rows in the same RecountTable buff family",
    evidence: stripEmpty({
      DamageAttrId: row.Id,
      BuffId: row.LinkedBuffId,
      RecountId: recount?.Id,
      SourceDamageAttrId: detail.sourceDamageAttrId,
      SourceBuffFamilyId: detail.buffFamilyId,
      LocalizedTermId: detail.localizedTermId
    })
  };
}

function buildSiblingSourceDetailLookup({ damageRows, damageToRecount, gameTerms }) {
  const out = new Map();
  for (const [id, row] of Object.entries(damageRows || {})) {
    if (!row || typeof row !== "object" || row.LinkedBuffId === undefined) {
      continue;
    }
    const recount = damageToRecount.get(String(id));
    const key = siblingBuffFamilyKey(recount?.Id, row.LinkedBuffId);
    if (!key) {
      continue;
    }
    const detail = chooseRawSourceDetailForSiblingLookup(row, gameTerms);
    if (!detail) {
      continue;
    }
    const existing = out.get(key);
    const detailCompare = compareNameText(detail.names, detail.name);
    if (existing) {
      const existingCompare = compareNameText(existing.names, existing.name);
      if (existingCompare && detailCompare && existingCompare !== detailCompare) {
        existing.ambiguous = true;
      }
      continue;
    }
    out.set(key, detail);
  }
  return out;
}

function chooseRawSourceDetailForSiblingLookup(row, gameTerms) {
  for (const rawValue of uniqueStringsInOrder([row.LinkedBuffName, row.Name, row.NameDesign])) {
    const bridge = resolveLocalizedDesignTerm(rawValue, gameTerms, { composeRoleNames: true });
    if (!bridge?.names || !hasRealLocale(bridge.names)) {
      continue;
    }
    if (hasWeakLocalizedSourceName(bridge.names)) {
      continue;
    }
    if (!hasExactCjkLocalizedTermMatch(bridge)) {
      continue;
    }
    return {
      name: bridge.name,
      names: normalizeNames(bridge.names, bridge.name),
      sourceDamageAttrId: row.Id,
      buffFamilyId: buffFamilyRoot(row.LinkedBuffId),
      localizedTermId: bridge.id
    };
  }
  return null;
}

function hasExactCjkLocalizedTermMatch(bridge) {
  const baseText = normalizeTermLookupText(bridge?.baseText || "");
  if (!baseText || !containsCjk(baseText)) {
    return true;
  }
  const names = bridge?.names || {};
  return [names["zh-CN"], names["zh-TW"], names.design]
    .map(normalizeTermLookupText)
    .some((value) => value && value === baseText);
}

function siblingBuffFamilyKey(recountId, buffId) {
  const group = Number(recountId);
  const family = buffFamilyRoot(buffId);
  if (!Number.isFinite(group) || !Number.isFinite(family) || family <= 0) {
    return "";
  }
  return `${group}:${family}`;
}

function buffFamilyRoot(buffId) {
  const value = Number(buffId);
  if (!Number.isFinite(value) || value <= 0) {
    return 0;
  }
  return Math.floor(value / 10) * 10;
}

function chooseDamageDesignTermDetail(row, gameTerms) {
  const damageName = `${row.NameDesign || ""} ${row.Name || ""}`;
  if (/强化重击|強化重擊|\u5f3a\u5316\u91cd\u51fb|\u5f37\u5316\u91cd\u64ca/i.test(damageName)) {
    const names = normalizeNames(gameTerms?.enhancedHeavyAttackDamage, "Enhanced heavy attack damage");
    if (row.NameDesign || row.Name) names.design = row.NameDesign || row.Name;
    return {
      kind: "localized-damage-term",
      name: chooseAnyName(names),
      names,
      source: "DamageAttr design phrase plus localized game term",
      evidence: stripEmpty({
        DamageAttrId: row.Id,
        DamageAttrName: row.NameDesign || row.Name,
        LocalizedTermId: TERM_ENHANCED_HEAVY_ATTACK_DAMAGE_ID
      })
    };
  }

  if (/重击|重擊|\u91cd\u51fb|\u91cd\u64ca|heavy attack/i.test(damageName)) {
    const names = normalizeNames(gameTerms?.heavyAttack, "Heavy Attack");
    if (row.NameDesign || row.Name) names.design = row.NameDesign || row.Name;
    return {
      kind: "localized-damage-term",
      name: chooseAnyName(names),
      names,
      source: "DamageAttr design phrase plus localized game term",
      evidence: stripEmpty({
        DamageAttrId: row.Id,
        DamageAttrName: row.NameDesign || row.Name,
        LocalizedTermId: TERM_HEAVY_ATTACK_ID
      })
    };
  }

  return null;
}

function isMonsterOwnedInternalSkill(row, category, sourceClassification) {
  if (category?.key !== "base-skill" || !sourceClassification?.monsterOwnerName) {
    return false;
  }
  const skillNames = firstNonEmptyObject(
    row.LinkedSkillEffectSkillTableNames,
    row.LinkedSkillTableNames,
    row.LinkedSkillFightSkillTableNames,
    row.LinkedSkillTableNameMatchNames
  );
  return !hasRealLocale(skillNames);
}

function isHeavyAttackFormula(row, underlying) {
  const damageName = `${row.NameDesign || ""} ${row.Name || ""}`;
  if (!/重击|重擊|\u91cd\u51fb|\u91cd\u64ca|heavy attack/i.test(damageName)) {
    return false;
  }
  const linkedName = [
    underlying?.name,
    row.LinkedSkillFightSkillTableName,
    row.LinkedSkillEffectSkillTableName,
    row.LinkedSkillTableName,
    row.LinkedSkillTableNameMatchName,
    row.LinkedSkillName
  ].filter(Boolean).join(" ");
  return /ATK[_-]?0?2/i.test(linkedName) || Boolean(resolveSkillTableParent(row).id);
}

function isQuadraflareAoeBuff(row, recount, category) {
  if (category.key !== "buff-proc") {
    return false;
  }
  const rawName = `${row.LinkedBuffName || ""} ${row.NameDesign || ""} ${row.Name || ""}`;
  const isTargetBuff = String(row.LinkedBuffId || "") === String(QUADRAFLARE_AOE_BUFF_ID) || /强化特攻小箭AOE/i.test(rawName);
  const isTargetRecount = String(recount?.Id || "") === String(QUADRAFLARE_RECOUNT_ID) || /Quadraflare|四连矢|四連矢/i.test(namesText(recount?.Names));
  return isTargetBuff && isTargetRecount;
}

function resolveSkillTableParent(row) {
  const candidates = [
    {
      childId: row.LinkedSkillFightSkillId,
      id: row.LinkedSkillFightSkillTableParentId,
      name: row.LinkedSkillFightSkillTableParentName,
      names: row.LinkedSkillFightSkillTableParentNames
    },
    {
      childId: row.LinkedSkillEffectSkillTableId,
      id: row.LinkedSkillEffectSkillTableParentId,
      name: row.LinkedSkillEffectSkillTableParentName,
      names: row.LinkedSkillEffectSkillTableParentNames
    },
    {
      childId: row.LinkedSkillTableId,
      id: row.LinkedSkillTableParentId,
      name: row.LinkedSkillTableParentName,
      names: row.LinkedSkillTableParentNames
    }
  ];

  for (const candidate of candidates) {
    if (candidate.id || candidate.name || Object.keys(candidate.names || {}).length) {
      return {
        ...candidate,
        name: candidate.name || chooseAnyName(candidate.names),
        names: normalizeNames(candidate.names, candidate.name)
      };
    }
  }
  return { childId: undefined, id: undefined, name: "", names: {} };
}

function composeLocaleNames(leftNames, rightNames, leftFallback, rightFallback) {
  return joinLocaleNames(leftNames, rightNames, leftFallback, rightFallback, ": ");
}

function joinLocaleNames(leftNames, rightNames, leftFallback, rightFallback, separator) {
  const left = normalizeNames(leftNames, leftFallback);
  const right = normalizeNames(rightNames, rightFallback);
  const out = {};
  const keys = uniqueStrings([
    ...Object.keys(left),
    ...Object.keys(right),
    "en",
    "zh-CN",
    "zh-TW",
    "ja",
    "ko-KR",
    "fr",
    "de",
    "es",
    "pt-BR",
    "th",
    "id"
  ]);
  const leftAny = chooseAnyName(left);
  const rightAny = chooseAnyName(right);
  for (const key of keys) {
    if (key === "design") {
      continue;
    }
    const leftText = left[key] || leftAny;
    const rightText = right[key] || rightAny;
    if (leftText && rightText) {
      out[key] = `${leftText}${separator}${rightText}`;
    }
  }
  return normalizeNames(out, [leftFallback, rightFallback].filter(Boolean).join(separator));
}

function buildReasons(row, recount, category, sourceClassification) {
  const reasons = [category.reason];
  if (row.DamageKind) reasons.push(`DamageKind=${row.DamageKind}`);
  if (row.LinkedSource) reasons.push(`LinkedSource=${row.LinkedSource}`);
  if (row.LinkedId !== undefined) reasons.push(`LinkedId=${row.LinkedId}`);
  if (recount?.Id !== undefined) reasons.push(`RecountId=${recount.Id}`);
  if (recount?.LinkedBaseSkillId !== undefined) reasons.push(`ParentBaseSkillId=${recount.LinkedBaseSkillId}`);
  if (recount?.BaseSkillNameBridge) reasons.push(`BaseSkillNameBridge=${recount.BaseSkillNameBridge}`);
  if (recount?.LinkedTalentId !== undefined) reasons.push(`TalentId=${recount.LinkedTalentId}`);
  if (recount?.TalentNameBridge) reasons.push(`TalentNameBridge=${recount.TalentNameBridge}`);
  if (recount?.TalentFormulaBridge) reasons.push(`TalentFormulaBridge=${recount.TalentFormulaBridge}`);
  if (Array.isArray(recount?.LinkedTalentBuffIds) && recount.LinkedTalentBuffIds.length) {
    reasons.push(`LinkedTalentBuffIds=${recount.LinkedTalentBuffIds.join(",")}`);
  }
  if (sourceClassification?.underlyingSkillId !== undefined) reasons.push(`UnderlyingSkillId=${sourceClassification.underlyingSkillId}`);
  if (sourceClassification?.relatedSkillIds?.length) {
    reasons.push(`UnderlyingRelatedSkillIds=${sourceClassification.relatedSkillIds.join(",")}`);
  }
  if (row.LinkedSkillTableNameMatchSource) reasons.push(`SkillTableNameMatch=${row.LinkedSkillTableNameMatchSource}`);
  if (sourceClassification?.recountOwnerSkillMismatch) reasons.push("Recount owner skill differs from underlying damage skill.");
  if (sourceClassification?.recountOwnerNameMismatch) reasons.push("Recount owner name differs from underlying damage skill.");
  if (sourceClassification?.monsterOwnerName) reasons.push(`MonsterOwner=${sourceClassification.monsterOwnerName}`);
  if (sourceClassification?.monsterOwnerIds?.length) reasons.push(`MonsterOwnerIds=${sourceClassification.monsterOwnerIds.join(",")}`);
  if (rowHasVirtualSkillNameBridge(row)) reasons.push("VirtualSkillNameBridge=CTB:3518555200");
  if (row.IconPath) reasons.push(`IconPath=${row.IconPath}`);
  return uniqueStrings(reasons);
}

function buildSourceFiles(row, recount, sourceClassification) {
  const sources = ["DamageAttrTable.ctb"];
  if (row.LinkedSource === "BuffName" || row.LinkedBuffId !== undefined) sources.push("BuffTable.ctb");
  if (row.LinkedSkillId !== undefined || row.LinkedSkillEffectId !== undefined || row.LinkedSkillEffectSkillTableId !== undefined) {
    sources.push("SkillEffectTable.ctb");
  }
  if (
    row.LinkedSkillTableId !== undefined ||
    row.LinkedSkillEffectSkillTableId !== undefined ||
    row.LinkedSkillFightSkillId !== undefined ||
    row.LinkedSkillTableNameMatchId !== undefined
  ) {
    sources.push("SkillTable.ctb");
  }
  if (row.LinkedSkillFightId !== undefined) sources.push("SkillFightLevelTable.ctb");
  if (recount) sources.push("RecountTable.ctb");
  if (recount?.LinkedBaseSkillId !== undefined) sources.push("SkillTable.ctb");
  if (recount?.LinkedTalentId !== undefined) sources.push("CTB:3345237628");
  if (sourceClassification?.monsterOwnerName || sourceClassification?.monsterOwnerIds?.length) {
    sources.push("MonsterTable.ctb");
  }
  if (rowHasVirtualSkillNameBridge(row)) {
    sources.push("CTB:3518555200");
  }
  for (const source of relationSourceFiles(sourceClassification?.skillRelations)) {
    sources.push(source);
  }
  return uniqueStrings(sources);
}

function relationSourceFiles(skillRelations) {
  const out = [];
  for (const relation of Array.isArray(skillRelations) ? skillRelations : []) {
    if (Array.isArray(relation?.TableHashes)) {
      for (const hash of relation.TableHashes) {
        if (Number.isFinite(Number(hash))) out.push(`CTB:${Number(hash)}`);
      }
    }
    if (Array.isArray(relation?.Sources)) {
      for (const source of relation.Sources) {
        const match = /^CTB:(\d+)/.exec(String(source || ""));
        if (match) out.push(`CTB:${match[1]}`);
      }
    }
  }
  return uniqueStrings(out);
}

function rowHasVirtualSkillNameBridge(row) {
  return [
    row.LinkedSkillTableNameSources,
    row.LinkedSkillEffectSkillTableNameSources,
    row.LinkedSkillFightSkillTableNameSources,
    row.LinkedSkillTableNameMatchNameSources
  ].some((sources) =>
    Array.isArray(sources) && sources.some((source) => String(source || "") === "CTB:3518555200.VirtualSkillNameBridge")
  );
}

function choosePreferredIcon(row, linked, recount, sourceClassification) {
  if (sourceClassification?.isTalent && recount?.LinkedTalentIconPath) {
    return {
      iconPath: recount.LinkedTalentIconPath,
      iconSource: recount.TalentFormulaBridge || recount.TalentNameBridge || "CTB:3345237628"
    };
  }
  if (sourceClassification?.recountOwnerSkillMismatch && recount?.LinkedBaseSkillIconPath) {
    return {
      iconPath: recount.LinkedBaseSkillIconPath,
      iconSource: "SkillTable.LocalizedNameMatch"
    };
  }
  if (sourceClassification?.recountOwnerNameMismatch && recount?.IconPath) {
    return {
      iconPath: recount.IconPath,
      iconSource: recount.IconSource || "RecountTable.DamageId"
    };
  }
  return {
    iconPath: row.IconPath || linked.iconPath || recount?.LinkedBaseSkillIconPath || recount?.LinkedTalentIconPath || recount?.IconPath || "",
    iconSource: row.IconSource || linked.iconSource || recount?.IconSource || ""
  };
}

function normalizeNames(names, fallback) {
  if (names && typeof names === "object" && !Array.isArray(names)) {
    const out = {};
    for (const [locale, value] of Object.entries(names)) {
      const text = String(value || "").trim();
      if (text) out[locale] = text;
    }
    if (Object.keys(out).length) return out;
  }
  const text = String(fallback || "").trim();
  return text ? { design: text } : {};
}

function firstNonEmptyObject(...values) {
  for (const value of values) {
    if (value && typeof value === "object" && !Array.isArray(value) && Object.keys(value).length) {
      return value;
    }
  }
  return {};
}

function hasRealLocale(names) {
  if (!names || typeof names !== "object" || Array.isArray(names)) return false;
  return Object.entries(names).some(([locale, value]) => locale !== "design" && String(value || "").trim());
}

function namesLookDifferent(leftNames, leftFallback, rightNames, rightFallback) {
  const left = compareNameText(leftNames, leftFallback);
  const right = compareNameText(rightNames, rightFallback);
  return Boolean(left && right && left !== right);
}

function compareNameText(names, fallback) {
  return normalizeCompareText(
    names?.en ||
    names?.["zh-CN"] ||
    names?.["zh-TW"] ||
    names?.design ||
    fallback
  );
}

function namesContainLookupText(names, value) {
  const key = normalizeTermLookupText(value);
  if (!key || !names || typeof names !== "object" || Array.isArray(names)) {
    return false;
  }
  return Object.values(names).some((text) => normalizeTermLookupText(text) === key);
}

function normalizeCompareText(value) {
  return String(value || "")
    .replace(/[\u200b-\u200f\ufeff]/g, "")
    .trim()
    .toLowerCase();
}

function isInternalFormulaLabel(value) {
  const text = String(value || "").trim();
  return (
    /^(?:EX_?)?ATK(?:_\d+|_EX)?$/i.test(text) ||
    /(?:ATK(?:_\d+|_EX)?|SPECIAL_SKILL(?:_[A-Z])?|UTR_SKILL)/i.test(text)
  );
}

function hasImplementationToken(value) {
  return /子?BUFF|aoe子buff|(?:^|[^A-Za-z])aoe(?:$|[^A-Za-z])|伤害区域|傷害區域|虚拟体|虛擬體|叠层|疊層|天赋|天賦|幸运|幸運|lucky|ATK[_-]?(?:EX|\d+)|SPECIAL_SKILL|UTR_SKILL/i.test(String(value || ""));
}

function hasInternalSkillImplementationToken(value) {
  return /(?:SKILL|ATK)(?:[_-]?[A-Z0-9]+)?/i.test(String(value || ""));
}

function isOwnerOnlyInternalDesignBridge(rawValue, bridge) {
  const raw = normalizeDesignText(rawValue);
  const base = normalizeDesignText(bridge?.baseText || bridge?.name || chooseAnyName(bridge?.names));
  if (!raw || !base || !bridge?.names || !hasRealLocale(bridge.names)) {
    return false;
  }
  if (!hasInternalSkillImplementationToken(raw)) {
    return false;
  }

  const stripped = stripDesignImplementationTokens(raw);
  return Boolean(stripped && normalizeTermLookupText(stripped) === normalizeTermLookupText(base));
}

function friendlyInternalDisplayNames(value, gameTerms) {
  const parsed = parseInternalSkillDesign(value);
  if (!parsed) {
    return null;
  }

  const prefixBridge = resolveLocalizedDesignTerm(parsed.prefix, gameTerms);
  const prefixNames = prefixBridge?.names && hasRealLocale(prefixBridge.names)
    ? normalizeNames(prefixBridge.names, parsed.prefix)
    : normalizeNames({ en: parsed.prefix }, parsed.prefix);
  const tokenNames = { en: parsed.label };
  const names = joinLocaleNames(prefixNames, tokenNames, parsed.prefix, parsed.label, " ");
  names.design = parsed.raw;
  return names;
}

function parseInternalSkillDesign(value) {
  const raw = normalizeDesignText(value);
  if (!raw) {
    return null;
  }
  const match = raw.match(/^(.{1,48}?)(?:[_\-\s]*)(SPECIAL_SKILL|UTR_SKILL|SKILL|ATK)(?:[_-]?([A-Za-z0-9]+(?:[_-][A-Za-z0-9]+)*))?$/i);
  if (!match) {
    return null;
  }

  const prefix = normalizeDesignText(match[1]);
  if (!prefix) {
    return null;
  }
  const token = String(match[2] || "").toUpperCase();
  const suffix = formatInternalSkillSuffix(match[3] || "");
  let label = token;
  if (token === "SKILL") {
    label = suffix ? `Skill ${suffix}` : "Skill";
  } else if (token === "ATK") {
    label = suffix ? `ATK_${suffix.replace(/\s+/g, "_")}` : "ATK";
  } else if (token === "SPECIAL_SKILL") {
    label = suffix ? `Special Skill ${suffix}` : "Special Skill";
  } else if (token === "UTR_SKILL") {
    label = suffix ? `UTR Skill ${suffix}` : "UTR Skill";
  }

  return { raw, prefix, token, suffix, label };
}

function formatInternalSkillSuffix(value) {
  return String(value || "")
    .split(/[_-]+/g)
    .map((part) => part.trim())
    .filter(Boolean)
    .map((part) => (/^\d+$/.test(part) ? part.padStart(2, "0") : part.toUpperCase()))
    .join(" ");
}

function containsCjk(value) {
  return /[\u3400-\u9fff]/.test(String(value || ""));
}

function friendlyInternalDetailName(value) {
  const text = String(value || "")
    .replace(/[\u200b-\u200f\ufeff]/g, "")
    .trim();
  if (!text) return "";
  if (/^(?:buff\s*)?aoe(?:子buff)?$/i.test(text)) return "AoE";
  const atkMatch = text.match(/ATK[_-]?0?(\d+)/i);
  if (atkMatch) return `ATK_${atkMatch[1].padStart(2, "0")}`;
  const suffix = text.split(/[-－]/).pop()?.trim() || "";
  if (/^[A-Za-z]+[_-]?\d+$/i.test(suffix)) return suffix.replace("-", "_");
  return "";
}

function chooseAnyName(names) {
  for (const key of ["en", "zh-CN", "zh-TW", "ja", "ko-KR", "fr", "de", "es", "pt-BR", "th", "id", "design"]) {
    const text = String(names?.[key] || "").trim();
    if (text) return text;
  }
  return "";
}

function firstDefined(...values) {
  for (const value of values) {
    if (value !== undefined && value !== null && value !== "") return value;
  }
  return undefined;
}

function stripEmpty(value) {
  const out = {};
  for (const [key, entry] of Object.entries(value)) {
    if (entry === undefined || entry === null || entry === "") continue;
    if (Array.isArray(entry) && !entry.length) continue;
    if (entry && typeof entry === "object" && !Array.isArray(entry) && !Object.keys(entry).length) continue;
    out[key] = entry;
  }
  return out;
}

function uniqueStrings(values) {
  return [...new Set((values || []).map((value) => String(value || "").trim()).filter(Boolean))]
    .sort((a, b) => a.localeCompare(b));
}

function uniqueNumbers(values) {
  return [...new Set((values || []).map(Number).filter((value) => Number.isFinite(value)))]
    .sort((a, b) => a - b);
}

function numberOrString(value) {
  const text = String(value);
  const numeric = Number(text);
  return Number.isSafeInteger(numeric) && String(numeric) === text ? numeric : text;
}

function compareNumericStrings(left, right) {
  try {
    const a = BigInt(left);
    const b = BigInt(right);
    return a < b ? -1 : a > b ? 1 : 0;
  } catch {
    return String(left).localeCompare(String(right));
  }
}
